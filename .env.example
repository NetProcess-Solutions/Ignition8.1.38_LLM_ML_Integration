# =============================================================================
# IgnitionChatbot - Environment Configuration
# Copy to .env and fill in your values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ignition_chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=change_me_in_production

# Full DSN used by the FastAPI service (override if not using compose defaults)
DATABASE_URL=postgresql+asyncpg://chatbot:change_me_in_production@postgres:5432/ignition_chatbot

# -----------------------------------------------------------------------------
# FastAPI service
# -----------------------------------------------------------------------------
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_LOG_LEVEL=INFO
SERVICE_ENV=development

# A shared secret the Ignition gateway sends in X-API-Key.
# Rotate this when staff turn over.
API_KEY=change_me_to_a_long_random_string

# -----------------------------------------------------------------------------
# LLM provider
# -----------------------------------------------------------------------------
# Provider: 'openai' | 'azure_openai' | 'local' (local not implemented in MVP)
LLM_PROVIDER=openai

# OpenAI direct
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=1500

# Azure OpenAI (used when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# -----------------------------------------------------------------------------
# Embedding model (runs locally inside the service container)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# -----------------------------------------------------------------------------
# Retrieval tuning
# -----------------------------------------------------------------------------
RETRIEVAL_TOP_K=10
RETRIEVAL_MIN_SCORE=0.30
RETRIEVAL_RECENT_EVENTS_HOURS=72
MEMORY_TOP_K=5

# -----------------------------------------------------------------------------
# Ignition-side
# -----------------------------------------------------------------------------
# Used only by Ignition gateway scripts; documented here so it's in one place.
IGNITION_AI_SERVICE_URL=http://ai-service:8000
